{
	"compilerOptions": {
		"target": "ES2020",
		"useDefineForClassFields": true,
		"lib": ["DOM", "DOM.Iterable", "ES2022"],
		"module": "ESNext",
		"skipLibCheck": true,
		"moduleResolution": "node",
		"allowImportingTsExtensions": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"jsx": "react-jsx",
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"types": ["vite/client", "node", "./worker-configuration.d.ts"],
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"baseUrl": ".",
		"paths": {
			"@tldraw/tldraw": ["./node_modules/@tldraw/tldraw"],
			"@tldraw/tlschema": ["./node_modules/@tldraw/tlschema"],
			"@tldraw/editor": ["./node_modules/@tldraw/editor"],
			"@tldraw/validate": ["./node_modules/@tldraw/validate"]
		}
	},
	"include": ["client", "worker", "vite.config.ts", "../shared/tldrawSchema.ts", "../shared/shapes"],
	"exclude": []
}
